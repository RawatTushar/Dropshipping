PORT=4000

# PostgreSQL Connection (Amazon RDS or local)
# Format: postgresql://username:password@host:port/database
POSTGRES_URL=postgresql://user:password@localhost:5432/dropshipping

# MongoDB (KEEP FOR MIGRATION ONLY - used by npm run migrate)
# After migration is complete, this can be removed
MONGO_URI=

# JWT Secret
JWT_SECRET=change-me-to-a-long-random-string

# Email Configuration
EMAIL_USER=
EMAIL_PASS=

# Set to true only when the API is served over HTTPS (not for http://localhost Docker)
COOKIE_SECURE=false

# EC2 gateway (port 80) — required for login cookies & CORS:
FRONTEND_URL=http://16.16.115.136
CLIENT_URL=http://16.16.115.136/admin
CORS_ORIGIN=http://16.16.115.136

# Google OAuth — must match Google Cloud Console redirect URIs (NOT localhost:4000 on EC2)
GOOGLE_REDIRECT_URI=http://16.16.115.136/api/auth/google/callback

# Stripe Checkout (card payments). Public product images in Stripe line items require HTTPS URLs.
STRIPE_SECRET_KEY=

# Local Development Notes:
# PostgreSQL local: POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/dropshipping
# Frontend (Vite dev): FRONTEND_URL=http://localhost:5173
# Frontend (nginx): FRONTEND_URL=http://localhost

