PORT=4000
# Set to true only when the API is served over HTTPS (not for http://localhost Docker)
COOKIE_SECURE=false
# Your MongoDB connection string (Atlas, local, or Docker — see docker-compose.yml)
MONGO_URI=
JWT_SECRET=
EMAIL_USER=
EMAIL_PASS=
# EC2 gateway (port 80):
FRONTEND_URL=http://16.171.135.147
CLIENT_URL=http://16.171.135.147/admin
# Local Docker: FRONTEND_URL=http://localhost  CLIENT_URL=http://localhost/admin
# Local Vite dev: FRONTEND_URL=http://localhost:5173
# Mongo in compose: MONGO_URI=mongodb://mongo:27017/dropshipping
# Stripe Checkout (card payments). Public product images in Stripe line items require HTTPS URLs.
STRIPE_SECRET_KEY=
