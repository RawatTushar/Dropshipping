PORT=4000
# Set to true only when the API is served over HTTPS (not for http://localhost Docker)
COOKIE_SECURE=false
# Your MongoDB connection string (Atlas, local, or Docker — see docker-compose.yml)
MONGO_URI=
JWT_SECRET=
EMAIL_USER=
EMAIL_PASS=
# Docker gateway (port 80): http://localhost — local Vite dev: http://localhost:5173
FRONTEND_URL=http://localhost
CLIENT_URL=http://localhost/admin
# Stripe Checkout (card payments). Public product images in Stripe line items require HTTPS URLs.
STRIPE_SECRET_KEY=
